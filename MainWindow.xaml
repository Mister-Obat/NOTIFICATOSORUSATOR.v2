<Window x:Class="Notificatosorusator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notificatosorusator - Audio Bridge" Height="520" Width="900"
        Background="#0F1115" Foreground="#E6EAF2"
        Icon="Images/logo.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBg" Color="#0F1115"/>
        <SolidColorBrush x:Key="PanelBg" Color="#161A22"/>
        <SolidColorBrush x:Key="PanelBgSoft" Color="#1C2230"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#2A3242"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E6EAF2"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9FA9BA"/>
        <SolidColorBrush x:Key="Accent" Color="#4CC2FF"/>
        <SolidColorBrush x:Key="Success" Color="#4ADE80"/>
        <SolidColorBrush x:Key="ScrollTrack" Color="#141B28"/>
        <SolidColorBrush x:Key="ScrollThumb" Color="#3A465A"/>
        <SolidColorBrush x:Key="ScrollThumbHover" Color="#4C5B73"/>
        <SolidColorBrush x:Key="VolumeTrack" Color="#2A3342"/>
        <SolidColorBrush x:Key="VolumeFill" Color="#40B9F6"/>
        <SolidColorBrush x:Key="DonateBorder" Color="#425066"/>
        <SolidColorBrush x:Key="DonateHover" Color="#1F2734"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="VolumeSliderRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Height="4"
                                VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSliderThumbStyle" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Width="12" Height="12" VerticalAlignment="Center">
                            <Ellipse Fill="#F2F8FF" Stroke="#1A2433" StrokeThickness="1"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSliderStyle" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Height="16">
                            <Border Height="4" Background="{StaticResource VolumeTrack}" CornerRadius="2" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}"
                                   IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Background="{StaticResource VolumeFill}"
                                                  Style="{StaticResource VolumeSliderRepeatButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource VolumeSliderThumbStyle}"
                                           VerticalAlignment="Center"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Background="Transparent"
                                                  Style="{StaticResource VolumeSliderRepeatButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DonateButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#DFE8F6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource DonateBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="{StaticResource DonateHover}"/>
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="MinWidth" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbRoot"
                                Background="{StaticResource ScrollThumb}"
                                CornerRadius="5"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource ScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalDarkScrollBarTemplate" TargetType="ScrollBar">
            <Border Background="{StaticResource ScrollTrack}" CornerRadius="6">
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True"
                       VerticalAlignment="Stretch"
                       HorizontalAlignment="Stretch"
                       Minimum="{TemplateBinding Minimum}"
                       Maximum="{TemplateBinding Maximum}"
                       Value="{TemplateBinding Value}"
                       ViewportSize="{TemplateBinding ViewportSize}">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageUpCommand"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkScrollThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageDownCommand"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalDarkScrollBarTemplate" TargetType="ScrollBar">
            <Border Background="{StaticResource ScrollTrack}" CornerRadius="6">
                <Track x:Name="PART_Track"
                       VerticalAlignment="Stretch"
                       HorizontalAlignment="Stretch"
                       Minimum="{TemplateBinding Minimum}"
                       Maximum="{TemplateBinding Maximum}"
                       Value="{TemplateBinding Value}"
                       ViewportSize="{TemplateBinding ViewportSize}">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkScrollThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageRightCommand"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <Style x:Key="DarkScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Background" Value="{StaticResource ScrollTrack}"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Template" Value="{StaticResource VerticalDarkScrollBarTemplate}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Template" Value="{StaticResource HorizontalDarkScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

        <Grid Background="{StaticResource PageBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="14,14,14,10" Padding="16,12"
                Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Notificatosorusator" FontSize="19" FontWeight="SemiBold"/>
                    <TextBlock Text="Audio bridge for task notifications" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource DonateButtonStyle}"
                        Click="DonateButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="♥" Margin="0,0,6,0" Foreground="#FF7A8D"/>
                        <TextBlock Text="Faire un don"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="14,0,14,10" Padding="12,10"
                Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                    <TextBlock Text="Sources actives :" Margin="0,0,14,0" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                    <CheckBox x:Name="SourceAntigravityCheckbox"
                              Content="Antigravity"
                              IsChecked="True"
                              Checked="SourceCheckboxChanged"
                              Unchecked="SourceCheckboxChanged"/>
                    <CheckBox x:Name="SourcePowerShellCheckbox"
                              Content="PowerShell"
                              IsChecked="True"
                              Checked="SourceCheckboxChanged"
                              Unchecked="SourceCheckboxChanged"/>
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Volume :" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                    <Slider Grid.Column="1"
                            x:Name="VolumeSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="100"
                            Style="{StaticResource VolumeSliderStyle}"
                            TickFrequency="5"
                            IsSnapToTickEnabled="False"
                            ValueChanged="VolumeSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2"
                               x:Name="VolumeValueText"
                               Text="100%"
                               Width="42"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="14,0,14,14" Padding="0"
                Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#121722" Padding="12,8" CornerRadius="10,10,0,0">
                    <TextBlock Text="Activity log" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                </Border>
                <TextBox x:Name="LogOutput" Grid.Row="1" Margin="0"
                         Background="#0E131D" Foreground="#C7D2E4"
                         BorderThickness="0" FontFamily="Consolas"
                         IsReadOnly="True" VerticalScrollBarVisibility="Visible"
                         TextWrapping="Wrap" Padding="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
