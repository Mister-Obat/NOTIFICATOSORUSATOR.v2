<Window x:Class="Notificatosorusator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notificatosorusator - Audio Bridge" Height="450" Width="800"
        Background="#1E1E1E" Foreground="White"
        Icon="Images/logo.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Notificatosorusator Listeners Active" 
                   FontSize="16" FontWeight="Bold" Margin="10" Foreground="#00FF00"/>

        <TextBox x:Name="LogOutput" Grid.Row="1" Margin="10"
                 Background="#252526" Foreground="#D4D4D4"
                 BorderThickness="0" FontFamily="Consolas"
                 IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" />
    </Grid>
</Window>
